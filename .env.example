# pawaPay (Mobile Money)
PAWAPAY_ENV=sandbox
PAWAPAY_API_TOKEN=your_pawapay_api_token_here
PAWAPAY_WEBHOOK_SECRET=your_pawapay_webhook_secret_here

# PesaPal (Card Payments)
PESAPAL_ENV=sandbox
PESAPAL_CONSUMER_KEY=your_pesapal_consumer_key_here
PESAPAL_CONSUMER_SECRET=your_pesapal_consumer_secret_here

# Supabase
NEXT_PUBLIC_PROJECT_URL=https://your-project.supabase.co
NEXT_PUBLIC_API_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# App
NEXT_PUBLIC_APP_URL=https://pay.techinika.com
